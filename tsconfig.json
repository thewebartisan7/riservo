{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@/*": ["./resources/js/*"]
        },
        "types": ["vite/client"],
        "isolatedModules": true,
        "noEmit": true,
        "allowImportingTsExtensions": true
    },
    "include": ["resources/js/**/*.ts", "resources/js/**/*.tsx"]
}
